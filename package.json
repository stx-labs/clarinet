{
  "name": "@stacks/clarinet-sdk-workspace",
  "private": true,
  "description": "Workspace hosting the Clarinet SDK for Node.js and Browser",
  "author": "Stacks Labs",
  "license": "GPL-3.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:sdk-wasm": "node components/clarinet-sdk-wasm/build.mjs",
    "build:sdk": "pnpm --filter ./components/clarinet-sdk/node --filter ./components/clarinet-sdk/browser run build",
    "test": "pnpm -r --if-present run test",
    "publish:sdk-wasm": "pnpm --filter ./components/clarinet-sdk-wasm/pkg-node --filter ./components/clarinet-sdk-wasm/pkg-browser publish --tag beta",
    "publish:sdk": "pnpm --filter ./components/clarinet-sdk/node --filter ./components/clarinet-sdk/browser publish --tag beta"
  },
  "devDependencies": {
    "@types/node": "24.0.14",
    "@types/prompts": "2.4.9",
    "@types/yargs": "17.0.35",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "ts-loader": "9.5.4",
    "typescript": "5.6.2"
  }
}
