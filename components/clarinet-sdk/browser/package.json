{
  "name": "@stacks/clarinet-sdk-browser",
  "version": "3.16.0",
  "author": "Stacks Labs",
  "description": "A SDK to interact with Clarity Smart Contracts in the browser",
  "homepage": "https://stackslabs.com/clarinet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stx-labs/clarinet"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/esm/browser/src/index.js",
  "types": "./dist/esm/browser/src/index.d.ts",
  "scripts": {
    "clean": "rimraf dist",
    "compile": "tsc -b ./tsconfig.json",
    "build": "pnpm run clean && pnpm run compile",
    "prepare": "pnpm run build",
    "prepublishOnly": "node ../../../scripts/require-pnpm.mjs"
  },
  "keywords": [
    "stacks",
    "clarity",
    "clarinet",
    "tests"
  ],
  "license": "GPL-3.0",
  "readme": "./README.md",
  "dependencies": {
    "@stacks/clarinet-sdk-wasm-browser": "workspace:*",
    "@stacks/transactions": "7.4.0"
  }
}
