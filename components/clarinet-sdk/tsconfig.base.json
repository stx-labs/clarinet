{
  "compilerOptions": {
    "rootDir": ".",

    "resolveJsonModule": false,
    "allowJs": false,

    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,

    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist"]
}
