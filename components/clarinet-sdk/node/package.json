{
  "name": "@stacks/clarinet-sdk",
  "version": "3.21.0",
  "author": "Stacks Labs",
  "description": "A SDK to interact with Clarity Smart Contracts in node.js",
  "homepage": "https://stackslabs.com/clarinet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stx-labs/clarinet"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "vitest-helpers/src"
  ],
  "main": "./dist/cjs/node/src/index.js",
  "module": "./dist/esm/node/src/index.js",
  "types": "./dist/esm/node/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/node/src/index.d.ts",
        "default": "./dist/esm/node/src/index.js"
      },
      "require": {
        "types": "./dist/cjs/node/src/index.d.ts",
        "default": "./dist/cjs/node/src/index.js"
      }
    },
    "./vitest": {
      "import": {
        "types": "./dist/esm/node/src/vitest/index.d.ts",
        "default": "./dist/esm/node/src/vitest/index.js"
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "compile": "tsc -b ./tsconfig.json ./tsconfig.cjs.json",
    "build": "pnpm run clean && pnpm run compile && node ./scripts/prepare-esm-package.js",
    "pretest": "tsc -b ./tsconfig.json",
    "test": "vitest run",
    "test:no-mxs": "vitest run --exclude=tests/remote-data.test.ts",
    "prepublishOnly": "node ../../../scripts/require-pnpm.mjs && pnpm run build"
  },
  "keywords": [
    "stacks",
    "clarity",
    "clarinet",
    "tests"
  ],
  "license": "GPL-3.0",
  "readme": "./README.md",
  "dependencies": {
    "@stacks/clarinet-sdk-wasm": "workspace:*",
    "@stacks/transactions": "7.4.0",
    "kolorist": "1.8.0",
    "prompts": "2.4.2",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@stacks/encryption": "7.4.0",
    "@stacks/network": "7.3.1",
    "@stacks/stacking": "7.4.0",
    "@types/node": "24.0.14",
    "@types/prompts": "2.4.9",
    "@types/yargs": "17.0.35",
    "vitest": "4.0.8"
  }
}
